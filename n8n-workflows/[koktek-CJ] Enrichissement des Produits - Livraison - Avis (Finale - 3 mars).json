    {
      "parameters": {
        "method": "POST",
        "url": "https://developers.cjdropshipping.com/api2.0/v1/logistic/freightCalculate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "CJ-Access-Token",
              "value": "API@CJ5158994@CJ:eyJhbGciOiJIUzI1NiJ9..MVX1SPGVbScWWJRw3Vu4Vx1Y8zNr8npAG3_FyzrEqCg"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"startCountryCode\": \"{{ $json.country_origin || 'CN' }}\",\n  \"endCountryCode\": \"FR\",\n  \"products\": [\n    {\n      \"quantity\": 1,\n      \"vid\": \"{{ $node[\"[PG] Récupérer 1 VID\"].json.cj_vid }}\"\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
