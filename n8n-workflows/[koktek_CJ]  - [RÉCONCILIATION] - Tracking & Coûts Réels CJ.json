        "query": "SELECT \n    o.id, \n    o.order_number,\n    o.status,\n    d.client_email,\n    d.client_nom_complet\nFROM \n    koktek.orders o\nLEFT JOIN \n    koktek.admin_orders_dashboard_final d ON o.order_number = d.order_number\nWHERE \n    (o.tracking_number IS NULL OR o.tracking_number = '') \n    AND o.status NOT IN ('canceled', 'refunded', 'Annulée', 'Remboursée');",
