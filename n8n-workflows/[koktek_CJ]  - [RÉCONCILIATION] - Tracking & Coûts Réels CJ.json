        "query": "UPDATE koktek.orders\nSET \n    tracking_number = '{{ $json.tracking_number }}',\n    tracking_url = NULLIF('{{ $json.tracking_url }}', 'null'),\n    logistic_name = NULLIF('{{ $json.logistic_name }}', 'null'),\n    shipping_price = {{ $json.vrai_cout_expedition }},\n    cj_order_id = '{{ $json.cj_order_id }}',\n    delivery_time_estimation = NULLIF('{{ $json.delai_estime }}', 'null'),\n    status = 'shipped'\nWHERE id = '{{ $json.id }}';",
        "options": {}
