    {
      "parameters": {
        "jsCode": "let cjResponse = $json.data || $json.result || $json;\n\n// Extraction de toutes les données\nlet tracking = cjResponse.trackNumber || null;\nlet tracking_url = cjResponse.trackingUrl || null;\nlet logistic_name = cjResponse.logisticName || null;\nlet vrai_cout_port = cjResponse.postageAmount || null;\nlet statut_cj = cjResponse.orderStatus || \"Inconnu\";\nlet cj_id = cjResponse.cjOrderCode || null; \n\n// La fameuse ligne pour le délai estimé :\nlet delai_estime = cjResponse.logisticsTimeliness || null; \n\nlet db_order_id = $('🔁 Boucler sur chaque Commande').item.json.id;\n\nreturn {\n  id: db_order_id,\n  tracking_number: tracking,\n  tracking_url: tracking_url,\n  logistic_name: logistic_name,\n  vrai_cout_expedition: vrai_cout_port,\n  cj_order_id: cj_id,\n  statut_cj: statut_cj,\n  delai_estime: delai_estime, // On l'ajoute au payload de sortie\n  pret_pour_maj: tracking ? true : false \n};"
      },
